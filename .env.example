# Discord Bot Configuration
TOKEN=your_discord_bot_token_here
CLIENT_ID=your_application_id_here

# DeepSeek/OpenAI API
OPENAI_API_KEY=your_api_key_here
CONVO_MODEL=model_name_here

# Google Gemini API (image understanding + image generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional
COOKIE=your_youtube_cookie_here
GENIUS_API_KEY=your_genius_key_here
GITHUB_TOKEN=your_github_token_here

ADDITIONAL_NOUNS=your,additional,nouns,here,separated,by,commas
ADDITIONAL_ADJECTIVES=your,additional,adjectives,here,separated,

# Discord IDs (required for full functionality)
GUILD_ID=your_server_id_here
BANNED_ROLE=your_banned_role_id_here
OWNER_ID=your_owner_id_here
CHATBOT_CHANNELS=your_chatbot_channel_id_here,another_chatbot_channel_id_here # separate multiple channels with commas
TESTING_ROLE=your_testing_role_id_here
RULES_CHANNEL_ID=your_rules_channel_id_here
WELCOME_CHANNEL_ID=your_welcome_channel_id_here
RIP_CHANNEL_ID=your_rip_channel_id_here
PHANTOM_CHANNEL_CATEGORY=your_category_id_here